<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectAssignmentController"
            prefWidth="450" prefHeight="300">
    <children>
        <Label text="Estudiante ID:" layoutX="30" layoutY="40"/>
        <TextField fx:id="txtEstudianteId" layoutX="180" layoutY="35" prefWidth="200"/>

        <Label text="Proyecto ID:" layoutX="30" layoutY="80"/>
        <TextField fx:id="txtProyectoId" layoutX="180" layoutY="75" prefWidth="200"/>

        <Label text="Profesor ID:" layoutX="30" layoutY="120"/>
        <TextField fx:id="txtProfesorId" layoutX="180" layoutY="115" prefWidth="200"/>

        <Label text="Fecha Asignación:" layoutX="30" layoutY="160"/>
        <DatePicker fx:id="dpFechaAsignacion" layoutX="180" layoutY="155" prefWidth="200"/>

        <Button text="Guardar" layoutX="180" layoutY="210" onAction="#handleSave"/>
        <Button text="Cancelar" layoutX="270" layoutY="210" onAction="#handleCancel"/>
    </children>
</AnchorPane>
