<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ReportController"
            prefWidth="450" prefHeight="300">
    <children>
        <Label text="Número de Reporte:" layoutX="30" layoutY="40"/>
        <TextField fx:id="txtNumero" layoutX="180" layoutY="35" prefWidth="200"/>

        <Label text="Observaciones:" layoutX="30" layoutY="80"/>
        <TextField fx:id="txtObservaciones" layoutX="180" layoutY="75" prefWidth="200"/>

        <Label text="Tipo:" layoutX="30" layoutY="120"/>
        <ComboBox fx:id="cmbTipo" layoutX="180" layoutY="115" prefWidth="200"/>

        <Label text="Ruta archivo:" layoutX="30" layoutY="160"/>
        <TextField fx:id="txtRutaArchivo" layoutX="180" layoutY="155" prefWidth="200"/>

        <Label text="Estudiante ID:" layoutX="30" layoutY="200"/>
        <TextField fx:id="txtEstudianteId" layoutX="180" layoutY="195" prefWidth="200"/>

        <Label text="Profesor ID:" layoutX="30" layoutY="240"/>
        <TextField fx:id="txtProfesorId" layoutX="180" layoutY="235" prefWidth="200"/>

        <Label text="Proyecto ID:" layoutX="30" layoutY="280"/>
        <TextField fx:id="txtProyectoId" layoutX="180" layoutY="275" prefWidth="200"/>

        <Button text="Guardar" layoutX="180" layoutY="320" onAction="#handleSave"/>
        <Button text="Cancelar" layoutX="270" layoutY="320" onAction="#handleCancel"/>
    </children>
</AnchorPane>
