<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F4F9, #EDEBFA);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ResendActivationTokenDashboardController">

    <children>

        <VBox alignment="CENTER"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <children>

                <VBox alignment="TOP_CENTER"
                      maxWidth="400.0"
                      prefWidth="400.0"
                      spacing="16.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: #E5E7EB;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.12), 18, 0.18, 0, 6);">

                    <padding>
                        <Insets top="35.0"
                                right="35.0"
                                bottom="35.0"
                                left="35.0"/>
                    </padding>

                    <children>

                        <Label text="Reenviar token"
                               style="-fx-font-size: 22;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1F2937;" />

                        <Label text="Ingresa tu correo institucional para recibir un nuevo token de activación."
                               wrapText="true"
                               style="-fx-font-size: 12;
                                      -fx-text-fill: #6B7280;"
                               textAlignment="CENTER"/>

                        <Region prefHeight="10.0"/>

                        <VBox spacing="5.0">

                            <children>

                                <Label text="Correo institucional"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <TextField fx:id="txtInstitutionalEmail"
                                           prefHeight="40.0"
                                           promptText="ejemplo@estudiantes.uv.mx"
                                           style="-fx-background-color: #F9FAFB;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 8;
                                                  -fx-padding: 0 10 0 10;" />

                            </children>

                        </VBox>

                        <Button text="Enviar nuevo token"
                                maxWidth="Infinity"
                                prefHeight="42.0"
                                onAction="#handleResendToken"
                                style="-fx-background-color: #534AB7;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;" />

                        <Button text="Volver a activar cuenta"
                                maxWidth="Infinity"
                                prefHeight="36.0"
                                onAction="#handleBackToActivation"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #534AB7;
                                       -fx-font-weight: bold;" />

                    </children>

                </VBox>

            </children>

        </VBox>

    </children>

</AnchorPane>