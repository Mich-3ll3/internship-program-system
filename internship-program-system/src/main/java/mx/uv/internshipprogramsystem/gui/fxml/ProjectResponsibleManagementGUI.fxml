<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectResponsibleManagementController">
    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <VBox>
                <Label text="Gestión de responsables de proyecto" textFill="#1a2744">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label text="Registro y consulta de responsables asociados a organizaciones vinculadas." textFill="#6b7280" />
            </VBox>

            <VBox spacing="12.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 12;">
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                </padding>
                <GridPane hgap="10.0" vgap="10.0">
                    <TextField fx:id="txtFirstName" promptText="Nombre(s)" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtLastNameFather" promptText="Apellido paterno" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <TextField fx:id="txtLastNameMother" promptText="Apellido materno" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <TextField fx:id="txtEmail" promptText="Correo" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="txtPosition" promptText="Cargo" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cmbOrganization" promptText="Organización" GridPane.columnIndex="2" GridPane.rowIndex="1">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="TecnoSoft" />
                                <String fx:value="Gobierno Municipal" />
                                <String fx:value="Clínica Regional" />
                            </FXCollections>
                        </items>
                    </ComboBox>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false"
                            onAction="#clearForm"
                            style="-fx-background-color: #f5f6fa; -fx-background-radius: 8; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 8; -fx-text-fill: #6b7280;"
                            text="Cancelar" />
                    <Button mnemonicParsing="false"
                            onAction="#validateResponsibleForm"
                            style="-fx-background-color: #4a90e2; -fx-background-radius: 8; -fx-text-fill: white;"
                            text="Validar responsable" />
                </HBox>
            </VBox>

            <VBox spacing="12.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 12;">
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                </padding>
                <HBox spacing="8.0">
                    <TextField fx:id="txtSearchEmail"
                               onAction="#validateSearchResponsible"
                               promptText="Buscar responsable por correo"
                               HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false"
                            onAction="#validateSearchResponsible"
                            style="-fx-background-color: #1a2744; -fx-background-radius: 8; -fx-text-fill: white;"
                            text="Buscar" />
                </HBox>
                <TableView fx:id="tblProjectResponsibles" prefHeight="230.0">
                    <columns>
                        <TableColumn fx:id="colFullName" prefWidth="220.0" text="Responsable" />
                        <TableColumn fx:id="colEmail" prefWidth="210.0" text="Correo" />
                        <TableColumn fx:id="colPosition" prefWidth="150.0" text="Cargo" />
                        <TableColumn fx:id="colOrganization" prefWidth="190.0" text="Organización" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
