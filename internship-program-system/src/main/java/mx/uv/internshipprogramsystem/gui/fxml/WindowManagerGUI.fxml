<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>

<BorderPane fx:id="mainLayout"
            prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controller.WindowManagerController">

    <top>
        <MenuBar prefHeight="26.0" BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="Archivo">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Cerrar Sesión" />
                        <MenuItem mnemonicParsing="false" text="Salir" />
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Gestión">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Alumnos" />
                        <MenuItem mnemonicParsing="false" text="Organizaciones" />
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Ayuda">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Acerca de" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane fx:id="containerArea"
                    style="-fx-background-color: #f5f6fa;"
                    BorderPane.alignment="CENTER" />
    </center>
</BorderPane>