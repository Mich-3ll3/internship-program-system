<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: #f5f6fa; -fx-background: #f5f6fa;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.RegisterSelfAssessmentController">
    
    <fx:define>
        <ToggleGroup fx:id="tgAfirmacion1" />
        <ToggleGroup fx:id="tgAfirmacion2" />
        <ToggleGroup fx:id="tgAfirmacion3" />
        <ToggleGroup fx:id="tgAfirmacion4" />
        <ToggleGroup fx:id="tgAfirmacion5" />
        <ToggleGroup fx:id="tgAfirmacion6" />
        <ToggleGroup fx:id="tgAfirmacion7" />
        <ToggleGroup fx:id="tgAfirmacion8" />
        <ToggleGroup fx:id="tgAfirmacion9" />
        <ToggleGroup fx:id="tgAfirmacion10" />
    </fx:define>

    <content>
        <VBox spacing="16.0" style="-fx-background-color: #f5f6fa;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Formulario de Autoevaluación" textFill="#1a2744">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblFecha" text="Fecha actual" textFill="#6b7280" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBack" text="← Volver" onAction="#goBack"
                                style="-fx-background-color: #e5e7eb; -fx-background-radius: 8;" />
                    </children>
                </HBox>

                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-background-radius: 13;
                             -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <StackPane prefHeight="32.0" prefWidth="32.0"
                                           style="-fx-background-color: #EEEDFE; -fx-background-radius: 9;">
                                    <children>
                                        <Label text="📋" />
                                    </children>
                                </StackPane>
                                <Label text="DATOS GENERALES" textFill="#1a2744">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Estudiante" textFill="#374151" />
                                        <ComboBox fx:id="cmbEstudiante" maxWidth="Infinity" promptText="Seleccionar estudiante" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Proyecto" textFill="#374151" />
                                        <ComboBox fx:id="cmbProyecto" maxWidth="Infinity" promptText="Seleccionar proyecto" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Organización" textFill="#374151" />
                                        <ComboBox fx:id="cmbOrganizacion" maxWidth="Infinity" promptText="Seleccionar organización" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Responsable del Proyecto" textFill="#374151" />
                                        <ComboBox fx:id="cmbResponsable" maxWidth="Infinity" promptText="Seleccionar responsable" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Departamento" textFill="#374151" />
                                        <TextField fx:id="txtDepartamento" promptText="Nombre del departamento" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Lugar" textFill="#374151" />
                                        <TextField fx:id="txtLugar" promptText="Lugar de la autoevaluación" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="Fecha" textFill="#374151" />
                                <DatePicker fx:id="dpFecha" maxWidth="250.0" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-background-radius: 13;
                             -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <StackPane prefHeight="32.0" prefWidth="32.0"
                                           style="-fx-background-color: #FEF3C7; -fx-background-radius: 9;">
                                    <children>
                                        <Label text="⭐" />
                                    </children>
                                </StackPane>
                                <Label text="EVALUACIÓN (1 = Muy en desacuerdo, 5 = Muy de acuerdo)" textFill="#1a2744">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="1. Cumplí con los objetivos establecidos para mis actividades." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion1" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion1" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion1" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion1" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion1" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="2. Mostré puntualidad y responsabilidad en mis tareas asignadas." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion2" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion2" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion2" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion2" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion2" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="3. Apliqué los conocimientos adquiridos en mi formación académica." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion3" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion3" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion3" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion3" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion3" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="4. Mantuve una comunicación efectiva con mi responsable de proyecto." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion4" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion4" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion4" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion4" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion4" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="5. Demostré iniciativa y proactividad en mis actividades." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion5" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion5" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion5" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion5" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion5" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="6. Trabajé de manera colaborativa con el equipo de trabajo." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion6" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion6" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion6" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion6" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion6" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="7. Respeté las normas y políticas de la organización." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion7" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion7" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion7" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion7" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion7" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="8. Desarrollé nuevas habilidades durante mis prácticas." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion8" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion8" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion8" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion8" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion8" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="9. Entregué productos o resultados de calidad." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion9" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion9" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion9" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion9" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion9" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label text="10. Estoy satisfecho con mi desempeño general en las prácticas." textFill="#374151" wrapText="true" />
                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <RadioButton text="1" toggleGroup="$tgAfirmacion10" userData="1" />
                                        <RadioButton text="2" toggleGroup="$tgAfirmacion10" userData="2" />
                                        <RadioButton text="3" toggleGroup="$tgAfirmacion10" userData="3" />
                                        <RadioButton text="4" toggleGroup="$tgAfirmacion10" userData="4" />
                                        <RadioButton text="5" toggleGroup="$tgAfirmacion10" userData="5" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="12.0"
                      style="-fx-background-color: white; -fx-background-radius: 13;
                             -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <StackPane prefHeight="32.0" prefWidth="32.0"
                                           style="-fx-background-color: #DCFCE7; -fx-background-radius: 9;">
                                    <children>
                                        <Label text="💬" />
                                    </children>
                                </StackPane>
                                <Label text="OBSERVACIONES" textFill="#1a2744">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <TextArea fx:id="txtObservaciones" 
                                  prefHeight="100.0" 
                                  promptText="Escribe tus observaciones adicionales aquí..."
                                  wrapText="true" />
                    </children>
                </VBox>

                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnCancelar" 
                                text="Cancelar" 
                                onAction="#handleCancel"
                                style="-fx-background-color: #e5e7eb; -fx-background-radius: 8; -fx-padding: 10 20;" />
                        <Button fx:id="btnGuardar" 
                                text="Guardar Autoevaluación" 
                                onAction="#handleSave"
                                style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20;" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </content>
</ScrollPane>