<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectsModuleDashboardController"
            style="-fx-background-color: #f4f7fb;">

    <children>

        <VBox spacing="20"
              AnchorPane.topAnchor="25"
              AnchorPane.leftAnchor="35"
              AnchorPane.rightAnchor="35"
              AnchorPane.bottomAnchor="25">

            <HBox spacing="20">

                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Proyectos"
                           style="-fx-font-size: 28px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #1e293b;" />

                    <Label text="Consulta y administración de proyectos"
                           style="-fx-font-size: 14px;
                                  -fx-text-fill: #64748b;" />
                </VBox>

                <Button fx:id="btnAddProject"
                        text="+ Agregar Proyecto"
                        onAction="#handleBtnAddProject"
                        style="-fx-background-color: #2563eb;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;" />
            </HBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER">

                <content>
                    <VBox fx:id="vbxProjectsContainer"
                          spacing="15"/>
                </content>

            </ScrollPane>

        </VBox>

    </children>

</AnchorPane>