<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ReportHomeDashboardController">

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="70.0" spacing="20.0" style="-fx-background-color:#4a90e2;" BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #e8a020; -fx-background-radius: 10;">
                    <VBox.margin><Insets top="20.0" /></VBox.margin>
                    <children>
                        <Label text="ES" textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                    </children>
                </StackPane>
                <Button fx:id="btnHome" text="⌂" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#goHome"/>
                <Button fx:id="btnProjects" text="🛠️" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#goProjectsModule"/>
                <Button fx:id="btnDocuments" text="📑" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#goDocumentsModule"/>
                
                <Button fx:id="btnReports" text="📋" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10; -fx-cursor: hand;"
                        onAction="#goReportsModule"/>
                        
                <Button fx:id="btnSelfAssessments" text="📝" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#goSelfAssessmentsModule"/>
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnExit" text="🚪" textFill="WHITE"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#logOut">
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: #f5f6fa;">
            <content>
                <VBox spacing="20.0">
                    <padding><Insets bottom="24.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <VBox>
                                    <children>
                                        <Label text="Panel de Estudiantes" textFill="#1a2744">
                                            <font><Font name="System Bold" size="24.0" /></font>
                                        </Label>
                                        <Label fx:id="lblFecha" text="Dashboard de Reportes" textFill="#6b7280">
                                            <font><Font size="13.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <StackPane prefHeight="40.0" prefWidth="40.0"
                                           style="-fx-background-color: #1a2744; -fx-background-radius: 50;">
                                    <children>
                                        <Label text="SF" textFill="WHITE">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <VBox spacing="20.0"
                              style="-fx-background-color: white; -fx-background-radius: 12; 
                                     -fx-border-color: #e5e7eb; -fx-border-radius: 12; 
                                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4);">
                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                            <children>
                                
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <StackPane prefHeight="36.0" prefWidth="36.0"
                                                   style="-fx-background-color: #EEEDFE; -fx-background-radius: 10;">
                                            <children>
                                                <Label text="R" textFill="#7c3aed">
                                                    <font><Font name="System Bold" size="16.0" /></font>
                                                </Label>
                                            </children>
                                        </StackPane>
                                        <Label text="Gestión de Reportes" textFill="#1a2744">
                                            <font><Font name="System Bold" size="16.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <HBox spacing="12.0">
                                    <children>
                                        <Button fx:id="btnRegisterReport" onAction="#openRegisterReport" text="➕ Nuevo Reporte"
                                                style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;" />
                                                
                                        <Button fx:id="btnGenerateReport" onAction="#generateReportPDF" text="📄 Generar PDF"
                                                style="-fx-background-color: white; -fx-text-fill: #4b5563; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;" />
                                                
                                        <Button fx:id="btnUploadPDF" onAction="#uploadReportFile" text="⬆️ Subir PDF Firmado"
                                                style="-fx-background-color: white; -fx-text-fill: #4b5563; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;" />
                                                
                                        <Button fx:id="btnSendReport" onAction="#sendReport" text="✉️ Enviar a Revisión"
                                                style="-fx-background-color: white; -fx-text-fill: #4b5563; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 16; -fx-cursor: hand;" />
                                    </children>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 5 0;">
                                    <children>
                                        <Label text="🔍 Buscar reporte:" textFill="#4b5563">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtSearchNumber" promptText="Número de reporte..." 
                                                   prefWidth="200.0"
                                                   style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 10;" />
                                        <Button text="Buscar" onAction="#handleSearch"
                                                style="-fx-background-color: white; -fx-text-fill: #4b5563; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" />
                                        <Button text="Limpiar" onAction="#handleClearSearch"
                                                style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-cursor: hand; -fx-underline: true;" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tblReports" prefHeight="280.0" 
                                           style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                                    <columns>
                                        <TableColumn fx:id="colNumber" text="Número" prefWidth="100"/>
                                        <TableColumn fx:id="colType" text="Tipo de Reporte" prefWidth="200"/>
                                        <TableColumn fx:id="colDate" text="Fecha de Registro" prefWidth="180"/>
                                        <TableColumn fx:id="colStatus" text="Estado Actual" prefWidth="180"/>
                                    </columns>
                                </TableView>

                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>