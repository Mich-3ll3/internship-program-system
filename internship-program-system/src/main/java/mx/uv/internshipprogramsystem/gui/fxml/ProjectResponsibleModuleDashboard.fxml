<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    prefHeight="700.0"
    prefWidth="1000.0"
    style="-fx-background-color: #f3f6fb;"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectResponsibleModuleDashboardController">

    <left>
        <VBox
            alignment="TOP_CENTER"
            prefWidth="72.0"
            spacing="22.0"
            style="-fx-background-color: #3f8fe5;"
            BorderPane.alignment="CENTER">

            <children>
                <StackPane
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: #f2a91b; -fx-background-radius: 12;">

                    <VBox.margin>
                        <Insets top="22.0" />
                    </VBox.margin>

                    <children>
                        <Label text="PC" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>

                <Button
                    fx:id="btnHome"
                    mnemonicParsing="false"
                    onAction="#goHome"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 12; -fx-cursor: hand;"
                    text="⌂"
                    textFill="WHITE" />

                <Button
                    fx:id="btnEducationalExperience"
                    mnemonicParsing="false"
                    onAction="#goEducationalExperienceModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="📚"
                    textFill="WHITE" />

                <Button
                    fx:id="btnIntern"
                    mnemonicParsing="false"
                    onAction="#goInternModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="👥"
                    textFill="WHITE" />

                <Button
                    fx:id="btnLinkedOrganization"
                    mnemonicParsing="false"
                    onAction="#goLinkedOrganizationModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🏢"
                    textFill="WHITE" />

                <Button
                    fx:id="btnProjects"
                    mnemonicParsing="false"
                    onAction="#goProjectsModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🛠️"
                    textFill="WHITE" />

                <Button
                    fx:id="btnDocuments"
                    mnemonicParsing="false"
                    onAction="#goDocumentsModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="📑"
                    textFill="WHITE" />

                <Button
                    fx:id="btnReports"
                    mnemonicParsing="false"
                    onAction="#goReportsModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="📋"
                    textFill="WHITE" />

                <Region VBox.vgrow="ALWAYS" />

                <Button
                    fx:id="btnExit"
                    mnemonicParsing="false"
                    onAction="#logOut"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🚪"
                    textFill="WHITE">

                    <VBox.margin>
                        <Insets bottom="22.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="18.0">
            <padding>
                <Insets bottom="26.0" left="30.0" right="30.0" top="28.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Gestión de responsables" textFill="#14213d">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>

                                <Label
                                    text="Consulta y registro de responsables de proyecto."
                                    textFill="#64748b">

                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Button
                            fx:id="btnNewResponsible"
                            mnemonicParsing="false"
                            onAction="#handleRegisterResponsible"
                            prefHeight="38.0"
                            style="-fx-background-color: #3f8fe5; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                            text="+ Nuevo responsable" />
                    </children>
                </HBox>

                <VBox
                    spacing="16.0"
                    style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0.16, 0, 4);">

                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField
                                    fx:id="txtSearch"
                                    onAction="#handleSearchResponsible"
                                    prefHeight="40.0"
                                    promptText="Buscar por nombre, correo, cargo, organización o proyecto"
                                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #cbd5e1; -fx-padding: 0 14 0 14;"
                                    HBox.hgrow="ALWAYS" />

                                <Button
                                    fx:id="btnSearch"
                                    mnemonicParsing="false"
                                    onAction="#handleSearchResponsible"
                                    prefHeight="40.0"
                                    style="-fx-background-color: #14213d; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Buscar" />

                                <Button
                                    fx:id="btnShowAll"
                                    mnemonicParsing="false"
                                    onAction="#handleShowAllResponsibles"
                                    prefHeight="40.0"
                                    style="-fx-background-color: #eef2f7; -fx-background-radius: 12; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Mostrar todos" />
                            </children>
                        </HBox>

                        <TableView
                            fx:id="tblProjectResponsibles"
                            prefHeight="390.0"
                            style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #dbe1ea; -fx-padding: 0; -fx-selection-bar: #dbeafe; -fx-selection-bar-non-focused: #dbeafe;">

                            <columns>
                                <TableColumn fx:id="colFullName" text="Nombre" />
                                <TableColumn fx:id="colEmail" text="Correo" />
                                <TableColumn fx:id="colPosition" text="Cargo" />
                                <TableColumn fx:id="colOrganization" text="Organización" />
                                <TableColumn fx:id="colProject" text="Proyecto" />
                            </columns>

                            <placeholder>
                                <Label
                                    text="No hay responsables registrados"
                                    textFill="#64748b" />
                            </placeholder>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>