<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.AdminHomeDashboardController">

    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="70.0"
              spacing="20.0"
              style="-fx-background-color:#4a90e2;">

            <children>

                <StackPane prefHeight="40.0"
                           prefWidth="40.0"
                           style="-fx-background-color: #e8a020; -fx-background-radius: 10;">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </StackPane>

                <Button fx:id="btnHome"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="⌂"
                        textFill="WHITE"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 10;"
                        onAction="#goHome"/>

                <Button fx:id="btnProfessor"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="🎓"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;"
                        onAction="#goProfessorModule"/>

                <Region VBox.vgrow="ALWAYS"/>

                <Button fx:id="btnExit"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="🚪"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;"
                        onAction="#logOut">
                    <VBox.margin>
                        <Insets bottom="20.0"/>
                    </VBox.margin>
                </Button>

            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="24.0">

            <padding>
                <Insets top="30.0"
                        right="30.0"
                        bottom="30.0"
                        left="30.0"/>
            </padding>

            <children>


                <HBox alignment="CENTER_LEFT"
                    spacing="10.0">

                  <VBox HBox.hgrow="ALWAYS">
                      <Label text="Panel de administrador">
                          <font>
                              <Font name="System Bold" size="26"/>
                          </font>
                      </Label>

                      <Label text="Bienvenido nuevamente"
                             textFill="#6b7280"/>
                  </VBox>

                  <Button text="👤"
                          prefWidth="40"
                          prefHeight="40"
                          onAction="#goProfile"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 20;
                                 -fx-border-radius: 20;
                                 -fx-border-color: #dbe1ea;"/>
              </HBox>


                <VBox spacing="10.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #e5e7eb;
                             -fx-border-radius: 16;
                             -fx-padding: 24;">

                    <Label fx:id="lblWelcomeUser"
                           text="Bienvenido"
                           textFill="#1a2744">
                        <font>
                            <Font name="System Bold"
                                  size="22.0"/>
                        </font>
                    </Label>

                    <Label text="Accede a los módulos del sistema desde este panel."
                           textFill="#6b7280"/>

                    <Label fx:id="lblDate"
                           textFill="#4a90e2"
                           style="-fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>

                </VBox>


                <Label text="MÓDULOS DISPONIBLES"
                       textFill="#6b7280"
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;"/>


                <VBox spacing="12.0"
                      maxWidth="320.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #dbeafe;
                             -fx-border-radius: 16;
                             -fx-padding: 20;">

                    <Label text="🎓 Profesores"
                           textFill="#1a2744">
                        <font>
                            <Font name="System Bold"
                                  size="18.0"/>
                        </font>
                    </Label>

                    <Label text="Gestión completa del personal docente."
                           wrapText="true"
                           textFill="#6b7280"/>

                    <Label text="✓ Consulta de profesores"
                           textFill="#166534"/>

                    <Label text="✓ Registro de profesores"
                           textFill="#166534"/>

                    <Label text="✓ Modificación de datos"
                           textFill="#166534"/>

                    <Label text="✓ Cambio de estado"
                           textFill="#166534"/>

                    <Button text="Ir al módulo"
                            onAction="#goProfessorModule"
                            style="-fx-background-color: #4a90e2;
                                   -fx-background-radius: 8;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 16 8 16;"/>

                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>