<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controller.ProfessorManagementController">
    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gestión de profesores" textFill="#1a2744">
                        <font>
                            <Font name="System Bold" size="22.0" />
                        </font>
                    </Label>
                    <Label text="Consulta, registro, modificación y cambio de estado de profesores." textFill="#6b7280" />
                </VBox>
                <Button mnemonicParsing="false"
                        onAction="#showPendingFunctionalityMessage"
                        style="-fx-background-color: #4a90e2; -fx-background-radius: 8; -fx-text-fill: white;"
                        text="+ Nuevo profesor" />
            </HBox>

            <VBox spacing="12.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 12;">
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <TextField fx:id="txtSearchStaffNumber"
                               onAction="#validateSearchProfessor"
                               promptText="Buscar por número de personal: 123456"
                               HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false"
                            onAction="#validateSearchProfessor"
                            style="-fx-background-color: #1a2744; -fx-background-radius: 8; -fx-text-fill: white;"
                            text="Buscar" />
                </HBox>

                <TableView fx:id="tblProfessors" prefHeight="310.0">
                    <columns>
                        <TableColumn fx:id="colStaffNumber" prefWidth="140.0" text="No. personal" />
                        <TableColumn fx:id="colName" prefWidth="210.0" text="Nombre" />
                        <TableColumn fx:id="colEmail" prefWidth="230.0" text="Correo institucional" />
                        <TableColumn fx:id="colCoordinator" prefWidth="120.0" text="Coordinador" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Estado" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <TextArea fx:id="txtProfessorDetails"
                              prefRowCount="3"
                              promptText="Detalle del profesor seleccionado..."
                              wrapText="true"
                              HBox.hgrow="ALWAYS" />
                    <VBox spacing="8.0">
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showPendingFunctionalityMessage" text="Modificar" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showPendingFunctionalityMessage" text="Cambiar estado" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
