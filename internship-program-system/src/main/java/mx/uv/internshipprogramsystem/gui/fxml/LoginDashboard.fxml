<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="650.0"
            prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F4F9, #EDEBFA);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.LoginDashboardController">

    <children>
        <VBox alignment="CENTER"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>
                <VBox alignment="TOP_CENTER"
                      maxWidth="390.0"
                      prefWidth="390.0"
                      spacing="14.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: #E5E7EB;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.12), 18, 0.18, 0, 6);">

                    <padding>
                        <Insets bottom="34.0"
                                left="34.0"
                                right="34.0"
                                top="34.0" />
                    </padding>

                    <children>
                        <Label text="Bienvenido"
                               style="-fx-font-size: 24;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1F2937;" />

                        <Label text="Inicia sesión con tu correo institucional."
                               wrapText="true"
                               textAlignment="CENTER"
                               style="-fx-font-size: 12;
                                      -fx-text-fill: #6B7280;" />

                        <Region prefHeight="8.0" />

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Correo electrónico"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <TextField fx:id="txtEmail"
                                           prefHeight="40.0"
                                           promptText="ejemplo@estudiantes.uv.mx"
                                           style="-fx-background-color: #F9FAFB;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 8;
                                                  -fx-padding: 0 10 0 10;" />

                                <Label fx:id="lblEmailError"
                                       textFill="#ef9f27"
                                       visible="false"
                                       managed="false"
                                       style="-fx-font-size: 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Contraseña"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <StackPane>
                                    <children>
                                        <PasswordField fx:id="pwdPassword"
                                                       prefHeight="40.0"
                                                       promptText="Ingresa tu contraseña"
                                                       onAction="#handleLoginAction"
                                                       style="-fx-background-color: #F9FAFB;
                                                              -fx-background-radius: 8;
                                                              -fx-border-color: #D1D5DB;
                                                              -fx-border-radius: 8;
                                                              -fx-padding: 0 45 0 10;" />

                                        <TextField fx:id="txtVisiblePassword"
                                                   visible="false"
                                                   managed="false"
                                                   prefHeight="40.0"
                                                   promptText="Ingresa tu contraseña"
                                                   onAction="#handleLoginAction"
                                                   style="-fx-background-color: #F9FAFB;
                                                          -fx-background-radius: 8;
                                                          -fx-border-color: #D1D5DB;
                                                          -fx-border-radius: 8;
                                                          -fx-padding: 0 45 0 10;" />

                                        <Button fx:id="btnTogglePasswordVisibility"
                                            onAction="#handleTogglePasswordVisibility"
                                            StackPane.alignment="CENTER_RIGHT"
                                            style="-fx-background-color: transparent;
                                                   -fx-padding: 0 12 0 0;">

                                        <graphic>
                                            <ImageView fx:id="imgPasswordVisibility"
                                                       fitWidth="18.0"
                                                       fitHeight="18.0"
                                                       preserveRatio="true" />
                                        </graphic>
                                    </Button>
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>

                        <Button fx:id="btnLogin"
                                text="Iniciar sesión"
                                maxWidth="Infinity"
                                prefHeight="42.0"
                                onAction="#handleLoginAction"
                                style="-fx-background-color: #534AB7;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;" />

                        <Button text="¿Olvidaste tu contraseña?"
                                maxWidth="Infinity"
                                prefHeight="34.0"
                                onAction="#handleOpenForgotPasswordView"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #534AB7;
                                       -fx-font-weight: bold;" />

                        <Button text="¿No tienes una cuenta? Regístrate"
                                maxWidth="Infinity"
                                prefHeight="36.0"
                                onAction="#handleOpenActivationView"
                                style="-fx-background-color: #EEF2FF;
                                       -fx-text-fill: #534AB7;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>