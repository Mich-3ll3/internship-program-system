<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane
    fx:controller="mx.uv.internshipprogramsystem.gui.controllers.CoordinatorProfessorHomeDashboardController"
    maxHeight="-Infinity"
    maxWidth="-Infinity"
    minHeight="-Infinity"
    minWidth="-Infinity"
    prefHeight="700.0"
    prefWidth="1000.0"
    style="-fx-background-color: #f5f6fa;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="70.0"
              spacing="18.0"
              style="-fx-background-color:#4a90e2;"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="20.0" bottom="20.0"/>
            </padding>

            <StackPane prefHeight="40.0"
                       prefWidth="40.0"
                       style="-fx-background-color: #e8a020; -fx-background-radius: 10;">

                <children>
                    <Label text="PC" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="12.0"/>
                        </font>
                    </Label>
                </children>
            </StackPane>

            <Button fx:id="btnHome"
                    mnemonicParsing="false"
                    onAction="#goHome"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 10;"
                    text="⌂"
                    textFill="WHITE"/>

            <Button fx:id="btnIntern"
                    mnemonicParsing="false"
                    onAction="#goInternModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="👥"
                    textFill="WHITE"/>

            <Button fx:id="btnReports"
                    mnemonicParsing="false"
                    onAction="#goReportsModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="📋"
                    textFill="WHITE"/>

            <Button fx:id="btnProjects"
                    mnemonicParsing="false"
                    onAction="#goProjectsModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🛠️"
                    textFill="WHITE"/>

            <Button fx:id="btnLinkedOrganization"
                    mnemonicParsing="false"
                    onAction="#goLinkedOrganizationModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="💼"
                    textFill="WHITE"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnExit"
                    mnemonicParsing="false"
                    onAction="#logOut"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🚪"
                    textFill="WHITE"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="12.0"
              style="-fx-background-color: #f5f6fa;">

            <padding>
                <Insets top="18.0"
                        right="22.0"
                        bottom="18.0"
                        left="22.0"/>
            </padding>

            <HBox spacing="12.0">

                <children>

                    <TabPane fx:id="tpCoordinatorDashboard"
                             tabClosingPolicy="UNAVAILABLE"
                             VBox.vgrow="ALWAYS">

                        <tabs>

                            <Tab text="Alumnos">

                                <content>

                                    <VBox spacing="8.0">

                                        <padding>
                                            <Insets top="10.0"/>
                                        </padding>

                                        <children>

                                            <HBox spacing="8.0">

                                                <children>

                                                    <TextField fx:id="txtSearchIntern"
                                                               onAction="#goConsultIntern"
                                                               promptText="Buscar alumno..."
                                                               HBox.hgrow="ALWAYS"/>

                                                    <Button fx:id="btnEvaluateIntern"
                                                            mnemonicParsing="false"
                                                            onAction="#evaluateIntern"
                                                            style="-fx-background-color: #1a2744; -fx-background-radius: 8; -fx-text-fill: white;"
                                                            text="Evaluar"/>

                                                    <Button fx:id="btnCommentIntern"
                                                            mnemonicParsing="false"
                                                            onAction="#commentIntern"
                                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                                            text="Comentar"/>
                                                </children>
                                            </HBox>

                                            <TableView fx:id="tvStudents"
                                                       prefHeight="245.0">

                                                <columns>

                                                    <TableColumn fx:id="colNameIntern"
                                                                 prefWidth="180.0"
                                                                 text="Alumno"/>

                                                    <TableColumn fx:id="colProjectIntern"
                                                                 prefWidth="220.0"
                                                                 text="Proyecto asignado"/>

                                                    <TableColumn fx:id="colStateIntern"
                                                                 prefWidth="120.0"
                                                                 text="Estado"/>
                                                </columns>
                                            </TableView>

                                            <TextArea fx:id="taInternEvaluation"
                                                      prefRowCount="3"
                                                      promptText="Evaluación o retroalimentación del alumno seleccionado..."
                                                      wrapText="true"/>
                                        </children>
                                    </VBox>
                                </content>
                            </Tab>

                            <Tab text="Proyectos">

                                <content>

                                    <VBox spacing="8.0">

                                        <padding>
                                            <Insets top="10.0"/>
                                        </padding>

                                        <children>

                                            <GridPane hgap="8.0"
                                                      vgap="8.0">

                                                <columnConstraints>

                                                    <ColumnConstraints percentWidth="25.0"/>
                                                    <ColumnConstraints percentWidth="25.0"/>
                                                    <ColumnConstraints percentWidth="25.0"/>
                                                    <ColumnConstraints percentWidth="25.0"/>
                                                </columnConstraints>

                                                <children>

                                                    <TextField fx:id="tfProjectName"
                                                               onAction="#addProject"
                                                               promptText="Nombre del proyecto"
                                                               GridPane.columnIndex="0"/>

                                                    <ComboBox fx:id="cbProjectOrg"
                                                              onAction="#filterResponsiblesByOrganization"
                                                              promptText="Organización"
                                                              GridPane.columnIndex="1"
                                                              maxWidth="Infinity"/>

                                                    <ComboBox fx:id="cbProjectManager"
                                                              promptText="Responsable"
                                                              GridPane.columnIndex="2"
                                                              maxWidth="Infinity"/>

                                                    <Button fx:id="btnAddProject"
                                                            mnemonicParsing="false"
                                                            onAction="#addProject"
                                                            style="-fx-background-color: #1a2744; -fx-background-radius: 8; -fx-text-fill: white;"
                                                            text="+ Proyecto"
                                                            GridPane.columnIndex="3"/>

                                                    <ComboBox fx:id="cbProjectIntern"
                                                              promptText="Alumno para asignar"
                                                              GridPane.columnIndex="0"
                                                              GridPane.columnSpan="2"
                                                              GridPane.rowIndex="1"
                                                              maxWidth="Infinity"/>

                                                    <Button fx:id="btnAssignProject"
                                                            mnemonicParsing="false"
                                                            onAction="#assignInternProject"
                                                            style="-fx-background-color: #e8a020; -fx-background-radius: 8; -fx-text-fill: white;"
                                                            text="Asignar proyecto a alumno"
                                                            GridPane.columnIndex="2"
                                                            GridPane.columnSpan="2"
                                                            GridPane.rowIndex="1"
                                                            maxWidth="Infinity"/>
                                                </children>

                                                <rowConstraints>
                                                    <RowConstraints/>
                                                    <RowConstraints/>
                                                </rowConstraints>
                                            </GridPane>
                                        </children>
                                    </VBox>
                                </content>
                            </Tab>

                        </tabs>
                    </TabPane>
                </children>
            </HBox>
        </VBox>
    </center>
</BorderPane>