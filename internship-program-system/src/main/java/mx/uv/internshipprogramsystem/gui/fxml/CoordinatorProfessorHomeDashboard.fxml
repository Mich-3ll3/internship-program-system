<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    fx:controller="mx.uv.internshipprogramsystem.gui.controllers.CoordinatorProfessorHomeDashboardController"
    maxHeight="-Infinity"
    maxWidth="-Infinity"
    minHeight="-Infinity"
    minWidth="-Infinity"
    prefHeight="700.0"
    prefWidth="1000.0"
    style="-fx-background-color: #f5f6fa;"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox
            alignment="TOP_CENTER"
            prefWidth="70.0"
            spacing="20.0"
            style="-fx-background-color:#4a90e2;"
            BorderPane.alignment="CENTER">

            <children>
                <StackPane
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: #e8a020; -fx-background-radius: 10;">

                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>

                    <children>
                        <Label text="PC" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>

                <Button
                    fx:id="btnHome"
                    mnemonicParsing="false"
                    onAction="#goHome"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;"
                    text="⌂"
                    textFill="WHITE" />

                <Button
                    fx:id="btnEducationalExperience"
                    mnemonicParsing="false"
                    onAction="#goEducationalExperienceModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="📚"
                    textFill="WHITE" />

                <Button
                    fx:id="btnIntern"
                    mnemonicParsing="false"
                    onAction="#goInternModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="👥"
                    textFill="WHITE" />

                <Button
                    fx:id="btnLinkedOrganization"
                    mnemonicParsing="false"
                    onAction="#goLinkedOrganizationModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🏢"
                    textFill="WHITE" />

                <Button
                    fx:id="btnProjects"
                    mnemonicParsing="false"
                    onAction="#goProjectsModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🛠️"
                    textFill="WHITE" />

                <Button
                    fx:id="btnDocuments"
                    mnemonicParsing="false"
                    onAction="#goDocumentsModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="📑"
                    textFill="WHITE" />

                <Button
                    fx:id="btnReports"
                    mnemonicParsing="false"
                    onAction="#goReportsModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="📋"
                    textFill="WHITE" />

                <Region VBox.vgrow="ALWAYS" />

                <Button
                    fx:id="btnExit"
                    mnemonicParsing="false"
                    onAction="#logOut"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🚪"
                    textFill="WHITE">

                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: #f5f6fa;">

            <content>
                <VBox spacing="16.0">
                    <padding>
                        <Insets
                            bottom="24.0"
                            left="24.0"
                            right="24.0"
                            top="20.0" />
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <VBox>
                                    <children>
                                        <Label
                                            text="Panel de Coordinación"
                                            textFill="#1a2744">

                                            <font>
                                                <Font name="System Bold" size="22.0" />
                                            </font>
                                        </Label>

                                        <Label
                                            fx:id="lblCurrentDate"
                                            text="Gestión general del programa de prácticas profesionales"
                                            textFill="#6b7280" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <StackPane
                                    prefHeight="35.0"
                                    prefWidth="35.0"
                                    style="-fx-background-color: #1a2744; -fx-background-radius: 50;">

                                    <children>
                                        <Label text="PC" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <HBox
                            alignment="CENTER_LEFT"
                            prefHeight="100.0"
                            spacing="18.0"
                            style="-fx-background-color: #4a90e2; -fx-background-radius: 10;">

                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>

                            <children>
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label
                                            style="-fx-text-fill: white; -fx-font-size: 14;"
                                            text="Bienvenido al módulo de coordinación" />

                                        <Label
                                            fx:id="lblCoordinatorName"
                                            style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"
                                            text="Profesor Coordinador" />

                                        <Label
                                            style="-fx-text-fill: #E5E7EB; -fx-font-size: 12;"
                                            text="Administre experiencias educativas, alumnos, proyectos, documentos y reportes." />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <GridPane hgap="12.0" vgap="12.0">
                            <columnConstraints>
                                <javafx.scene.layout.ColumnConstraints percentWidth="33.33" />
                                <javafx.scene.layout.ColumnConstraints percentWidth="33.33" />
                                <javafx.scene.layout.ColumnConstraints percentWidth="33.33" />
                            </columnConstraints>

                            <children>
                                <VBox
                                    fx:id="pneEducationalExperienceCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="0">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="📚" style="-fx-font-size: 24;" />
                                        <Label text="Experiencias educativas" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Registre experiencias educativas y asigne estudiantes."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenEducationalExperience"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goEducationalExperienceModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneInternCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="0">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="👥" style="-fx-font-size: 24;" />
                                        <Label text="Alumnos" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Consulte alumnos, avances y asignaciones."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenIntern"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goInternModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneOrganizationCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="2"
                                    GridPane.rowIndex="0">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="🏢" style="-fx-font-size: 24;" />
                                        <Label text="Organizaciones" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Registre organizaciones vinculadas y sus datos."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenLinkedOrganization"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goLinkedOrganizationModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneResponsibleCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="1">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="💼" style="-fx-font-size: 24;" />
                                        <Label text="Responsables" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Administre responsables asociados a organizaciones."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenResponsible"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goResponsibleModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneProjectCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="1">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="🛠️" style="-fx-font-size: 24;" />
                                        <Label text="Proyectos" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Registre proyectos y asigne responsables."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenProject"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goProjectsModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneRequestCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="2"
                                    GridPane.rowIndex="1">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="📌" style="-fx-font-size: 24;" />
                                        <Label text="Solicitudes" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Revise solicitudes de proyectos y registre asignaciones."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenRequest"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goProjectRequestModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneDocumentCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="0"
                                    GridPane.rowIndex="2">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="📑" style="-fx-font-size: 24;" />
                                        <Label text="Documentos" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Consulte documentos, fechas límite y observaciones."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenDocument"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goDocumentsModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneReportCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="1"
                                    GridPane.rowIndex="2">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="📋" style="-fx-font-size: 24;" />
                                        <Label text="Reportes" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Revise reportes, actividades y retroalimentación."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenReport"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goReportsModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>

                                <VBox
                                    fx:id="pneTrackingCard"
                                    spacing="10.0"
                                    style="-fx-background-color: white; -fx-background-radius: 13; -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;"
                                    GridPane.columnIndex="2"
                                    GridPane.rowIndex="2">

                                    <padding>
                                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                    </padding>

                                    <children>
                                        <Label text="📈" style="-fx-font-size: 24;" />
                                        <Label text="Seguimiento" textFill="#1a2744">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <Label
                                            text="Visualice el avance general de alumnos y proyectos."
                                            textFill="#6b7280"
                                            wrapText="true" />
                                        <Button
                                            fx:id="btnOpenTracking"
                                            maxWidth="Infinity"
                                            mnemonicParsing="false"
                                            onAction="#goTrackingModule"
                                            style="-fx-background-color: #EBF3FF; -fx-background-radius: 8; -fx-text-fill: #1d4ed8;"
                                            text="Abrir módulo" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>