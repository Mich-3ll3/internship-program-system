<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    prefHeight="700.0"
    prefWidth="1000.0"
    style="-fx-background-color: #f5f6fa;"
    xmlns="http://javafx.com/javafx/26"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectResponsibleRegisterDashboardController">

    <left>
        <VBox
            alignment="TOP_CENTER"
            prefWidth="70.0"
            spacing="20.0"
            style="-fx-background-color:#4a90e2;"
            BorderPane.alignment="CENTER">

            <children>
                <StackPane
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: #e8a020; -fx-background-radius: 10;">

                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>

                    <children>
                        <Label text="PC" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>

                <Button
                    fx:id="btnHome"
                    mnemonicParsing="false"
                    onAction="#goHome"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="⌂"
                    textFill="WHITE" />

                <Button
                    fx:id="btnResponsible"
                    mnemonicParsing="false"
                    onAction="#goResponsibleModule"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;"
                    text="💼"
                    textFill="WHITE" />

                <Region VBox.vgrow="ALWAYS" />

                <Button
                    fx:id="btnExit"
                    mnemonicParsing="false"
                    onAction="#logOut"
                    prefHeight="40.0"
                    prefWidth="40.0"
                    style="-fx-background-color: transparent;"
                    text="🚪"
                    textFill="WHITE">

                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets
                    top="24.0"
                    right="28.0"
                    bottom="24.0"
                    left="28.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label
                                    text="Registrar responsable"
                                    textFill="#1a2744">

                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>

                                <Label
                                    text="Ingrese los datos del responsable asignado a una organización vinculada."
                                    textFill="#6b7280" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox
                    spacing="20.0"
                    style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 16;">

                    <padding>
                        <Insets
                            top="28.0"
                            right="28.0"
                            bottom="28.0"
                            left="28.0" />
                    </padding>

                    <children>
                        <GridPane hgap="22.0" vgap="18.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50.0" />
                                <ColumnConstraints percentWidth="50.0" />
                            </columnConstraints>

                            <children>
                                <VBox spacing="7.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label
                                            text="Nombre *"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <TextField
                                            fx:id="txtFirstName"
                                            prefHeight="44.0"
                                            promptText="Nombre(s)"
                                            style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d1d5db; -fx-background-color: white; -fx-padding: 10; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label
                                            text="Apellido paterno *"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <TextField
                                            fx:id="txtLastNameFather"
                                            prefHeight="44.0"
                                            promptText="Apellido paterno"
                                            style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d1d5db; -fx-background-color: white; -fx-padding: 10; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label
                                            text="Apellido materno"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <TextField
                                            fx:id="txtLastNameMother"
                                            prefHeight="44.0"
                                            promptText="Apellido materno"
                                            style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d1d5db; -fx-background-color: white; -fx-padding: 10; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label
                                            text="Correo electrónico *"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <TextField
                                            fx:id="txtEmail"
                                            prefHeight="44.0"
                                            promptText="correo@empresa.com"
                                            style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d1d5db; -fx-background-color: white; -fx-padding: 10; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <Label
                                            text="Cargo *"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <TextField
                                            fx:id="txtPosition"
                                            prefHeight="44.0"
                                            promptText="Cargo dentro de la organización"
                                            style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d1d5db; -fx-background-color: white; -fx-padding: 10; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="7.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <Label
                                            text="Organización vinculada *"
                                            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2744;" />

                                        <ComboBox
                                            fx:id="cmbLinkedOrganization"
                                            maxWidth="Infinity"
                                            prefHeight="44.0"
                                            promptText="Seleccione una organización"
                                            style="
                                                -fx-background-radius: 12;
                                                -fx-border-radius: 12;
                                                -fx-border-color: #d1d5db;
                                                -fx-background-color: white;
                                                -fx-font-size: 14px;
                                            " />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <Label
                            text="Los campos marcados con * son obligatorios."
                            textFill="#6b7280"
                            wrapText="true" />

                        <HBox
                            alignment="CENTER"
                            spacing="16.0">

                            <children>
                                <Button
                                    mnemonicParsing="false"
                                    onAction="#handleRegisterProjectResponsible"
                                    prefHeight="44.0"
                                    prefWidth="220.0"
                                    style="-fx-background-color: #4a90e2; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold;"
                                    text="Registrar" />

                                <Button
                                    mnemonicParsing="false"
                                    onAction="#clearForm"
                                    prefHeight="44.0"
                                    prefWidth="220.0"
                                    style="-fx-background-color: #e5e7eb; -fx-background-radius: 12; -fx-text-fill: #1a2744; -fx-font-weight: bold;"
                                    text="Cancelar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>