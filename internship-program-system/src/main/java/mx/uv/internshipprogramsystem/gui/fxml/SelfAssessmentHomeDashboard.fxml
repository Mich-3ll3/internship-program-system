<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.SelfAssessmentHomeDashboardController">

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="70.0" spacing="20.0" style="-fx-background-color:#4a90e2;" BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #e8a020; -fx-background-radius: 10;">
                    <VBox.margin><Insets top="20.0" /></VBox.margin>
                    <children>
                        <Label text="ES" textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                    </children>
                </StackPane>

                <Button fx:id="btnHome" text="⌂" textFill="WHITE"
                        onAction="#goHome"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;"/>

                <Button fx:id="btnProjects" text="🛠️" textFill="WHITE"
                        onAction="#goProjectsModule"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent;"/>

                <Button fx:id="btnDocuments" text="📑" textFill="WHITE"
                        onAction="#goDocumentsModule"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent;"/>

                <Button fx:id="btnReports" text="📋" textFill="WHITE"
                        onAction="#goReportsModule"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent;"/>

                <Button fx:id="btnSelfAssessments" text="📝" textFill="WHITE"
                        onAction="#goSelfAssessmentsModule"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent;"/>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnExit" text="🚪" textFill="WHITE"
                        onAction="#logOut"
                        prefHeight="40.0" prefWidth="40.0"
                        style="-fx-background-color: transparent;">
                    <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: #f5f6fa;">
            <content>
                <VBox spacing="16.0">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="20.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <VBox>
                                    <children>
                                        <Label text="Panel de Estudiantes" textFill="#1a2744">
                                            <font><Font name="System Bold" size="22.0" /></font>
                                        </Label>
                                        <Label fx:id="lblDate" text="Jueves, 21 de mayo de 2026" textFill="#6b7280" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <StackPane prefHeight="35.0" prefWidth="35.0" style="-fx-background-color: #1a2744; -fx-background-radius: 50;">
                                    <children>
                                        <Label text="SF" textFill="WHITE">
                                            <font><Font name="System Bold" size="11.0" /></font>
                                        </Label>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <VBox spacing="10.0"
                              style="-fx-background-color: white; -fx-background-radius: 13;
                                     -fx-border-color: rgba(0,0,0,0.07); -fx-border-radius: 13;">
                            <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <StackPane prefHeight="32.0" prefWidth="32.0"
                                                   style="-fx-background-color: #FEF3E7; -fx-background-radius: 9;">
                                            <children>
                                                <Label text="A" textFill="#e8a020" />
                                            </children>
                                        </StackPane>
                                        <Label text="AUTOEVALUACIONES" textFill="#1a2744">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <HBox spacing="8.0">
                                    <children>
                                        <Button fx:id="btnRegisterSelfAssessment"
                                                onAction="#openRegisterSelfAssessment"
                                                text="Registrar autoevaluación" />
                                        <Button fx:id="btnPrintSelfAssessment"
                                                onAction="#printSelfAssessment"
                                                text="Imprimir autoevaluación" />
                                    </children>
                                </HBox>

                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Buscar por nombre:" textFill="#1a2744" />
                                        <TextField fx:id="txtSearchName" promptText="Ej. Proyecto A" />
                                        <Button text="Buscar" onAction="#handleSearchByName" />
                                        <Button text="Limpiar" onAction="#handleClearSearchByName" />
                                    </children>
                                </HBox>

                                <TableView fx:id="tblSelfAssessments" prefHeight="200.0" prefWidth="600.0">
                                    <columns>
                                        <TableColumn fx:id="colStudent" text="Estudiante" prefWidth="150"/>
                                        <TableColumn fx:id="colProject" text="Proyecto" prefWidth="150"/>
                                        <TableColumn fx:id="colResponsible" text="Responsable" prefWidth="150"/>
                                        <TableColumn fx:id="colOrganization" text="Organización" prefWidth="150"/>
                                        <TableColumn fx:id="colDate" text="Fecha" prefWidth="120"/>
                                        <TableColumn fx:id="colDepartment" text="Departamento" prefWidth="150"/>
                                        <TableColumn fx:id="colPlace" text="Lugar" prefWidth="150"/>
                                    </columns>
                                </TableView>

                                <Button fx:id="btnConsultSelfAssessment"
                                        onAction="#consultSelfAssessment"
                                        text="Consultar autoevaluación" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
