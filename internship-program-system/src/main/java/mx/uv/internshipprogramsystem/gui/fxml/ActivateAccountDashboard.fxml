<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="800.0"
            style="-fx-background-color: #F4F4F9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ActivateAccountDashboardController">
    <children>
        <VBox alignment="TOP_CENTER"
              layoutX="220.0"
              layoutY="70.0"
              prefWidth="360.0"
              spacing="12.0"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <children>
                <Label style="-fx-font-size: 20; -fx-font-weight: bold;"
                       text="Activar cuenta" />

                <VBox spacing="3.0">
                    <children>
                        <Label style="-fx-font-size: 11;" text="Token de activación" />
                        <TextField fx:id="txtActivationToken"
                                   prefHeight="35.0"
                                   style="-fx-background-color: transparent; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" />
                    </children>
                </VBox>

                <VBox spacing="3.0">
                    <children>
                        <Label style="-fx-font-size: 11;" text="Nueva contraseña" />
                        <PasswordField fx:id="pwdNewPassword"
                                       prefHeight="35.0"
                                       style="-fx-background-color: transparent; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" />
                    </children>
                </VBox>

                <VBox spacing="3.0">
                    <children>
                        <Label style="-fx-font-size: 11;" text="Confirmar contraseña" />
                        <PasswordField fx:id="pwdConfirmPassword"
                                       prefHeight="35.0"
                                       style="-fx-background-color: transparent; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;" />
                    </children>
                </VBox>

                <Button maxWidth="Infinity"
                        onAction="#handleActivateAccount"
                        prefHeight="40.0"
                        style="-fx-background-color: #534AB7; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                        text="Activar cuenta" />

                <Button maxWidth="Infinity"
                        onAction="#handleBackToLogin"
                        prefHeight="35.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #534AB7; -fx-font-weight: bold;"
                        text="Volver al inicio de sesión" />
            </children>
        </VBox>
    </children>
</AnchorPane>