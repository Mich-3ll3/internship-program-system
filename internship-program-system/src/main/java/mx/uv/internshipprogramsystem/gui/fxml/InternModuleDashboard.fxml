<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.InternManagementController">
    
    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="70.0"
              spacing="20.0"
              style="-fx-background-color:#4a90e2;"
              BorderPane.alignment="CENTER">
            <children>
                <StackPane prefHeight="40.0"
                           prefWidth="40.0"
                           style="-fx-background-color: #e8a020; -fx-background-radius: 10;">
                    <VBox.margin> 
                        <Insets top="20.0" />
                    </VBox.margin>
                </StackPane>
                <Button fx:id="btnHome" 
                        mnemonicParsing="false" 
                        prefHeight="40.0" 
                        prefWidth="40.0" 
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;" 
                        text="⌂" 
                        textFill="WHITE"
                        onAction="#goHome"/>
                <Button fx:id="btnProfessor"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        style="-fx-background-color: transparent;" 
                        text="🎓"
                        textFill="WHITE"
                        onAction = "#goProfessorModule"/>
                <Button fx:id="btnIntern"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;"
                        text="👥"
                        textFill="WHITE"
                        onAction = "#goInternModule"/>
                        <Region VBox.vgrow="ALWAYS" />
                <Button  fx:id="btnExit"
                        mnemonicParsing="false"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        style="-fx-background-color: transparent;"
                        text="🚪"
                        textFill="WHITE"
                        onAction="#logOut">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gestión de estudiantes" textFill="#1a2744">
                        <font>
                            <Font name="System Bold" size="22.0" />
                        </font>
                    </Label>
                    <Label text="Consulta, registro, modificación y cambio de estado de estudiantes." textFill="#6b7280" />
                </VBox>
                <Button mnemonicParsing="false"
                        onAction="#goRegisterIntern"
                        style="-fx-background-color: #4a90e2; -fx-background-radius: 8; -fx-text-fill: white;"
                        text="+ Nuevo estudiante" />
            </HBox>

            <VBox spacing="12.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 12;">
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <TextField fx:id="txtSearchEnrollment"
                               onAction="#searchIntern"
                               promptText="Buscar por matrícula: zS12345678"
                               HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false"
                            onAction="#searchIntern"
                            style="-fx-background-color: #1a2744; -fx-background-radius: 8; -fx-text-fill: white;"
                            text="Buscar" />
                </HBox>

                <TableView fx:id="tblInterns" prefHeight="310.0">
                    <columns>
                        <TableColumn fx:id="colEnrollment" prefWidth="130.0" text="Matrícula" />
                        <TableColumn fx:id="colName" prefWidth="210.0" text="Nombre" />
                        <TableColumn fx:id="colEmail" prefWidth="230.0" text="Correo institucional" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Estado" />
                        <TableColumn fx:id="colNRC" prefWidth="120.0" text="NRC" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <TextArea fx:id="txtInternDetails"
                              prefRowCount="3"
                              promptText="Detalle del estudiante seleccionado..."
                              wrapText="true"
                              HBox.hgrow="ALWAYS" />
                    <VBox spacing="8.0">
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#goUpdateIntern" text="Modificar" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleChangeInternStatus" text="Cambiar estado" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
