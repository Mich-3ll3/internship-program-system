<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    prefHeight="700.0"
    prefWidth="1000.0"
    style="-fx-background-color: #f3f6fb;"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="mx.uv.internshipprogramsystem.gui.controllers.InternManagementController">

    <left>
        <VBox
            alignment="TOP_CENTER"
            prefWidth="72.0"
            spacing="22.0"
            style="-fx-background-color: #3f8fe5;"
            BorderPane.alignment="CENTER">

            <children>
                <StackPane
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: #f2a91b; -fx-background-radius: 12;">

                    <VBox.margin>
                        <Insets top="22.0" />
                    </VBox.margin>
                </StackPane>

                <Button
                    fx:id="btnHome"
                    mnemonicParsing="false"
                    onAction="#handleGoHome"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 12; -fx-cursor: hand;"
                    text="⌂"
                    textFill="WHITE" />

                <Button
                    fx:id="btnProfessor"
                    mnemonicParsing="false"
                    onAction="#handleGoProfessorModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🎓"
                    textFill="WHITE" />

                <Button
                    fx:id="btnIntern"
                    mnemonicParsing="false"
                    onAction="#handleGoInternModule"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: rgba(255,255,255,0.16); -fx-background-radius: 12; -fx-cursor: hand;"
                    text="👥"
                    textFill="WHITE" />

                <Region VBox.vgrow="ALWAYS" />

                <Button
                    fx:id="btnExit"
                    mnemonicParsing="false"
                    onAction="#handleLogOut"
                    prefHeight="42.0"
                    prefWidth="42.0"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"
                    text="🚪"
                    textFill="WHITE">

                    <VBox.margin>
                        <Insets bottom="22.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="18.0">
            <padding>
                <Insets
                    bottom="26.0"
                    left="30.0"
                    right="30.0"
                    top="28.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label
                                    text="Gestión de estudiantes"
                                    textFill="#14213d">

                                    <font>
                                        <Font
                                            name="System Bold"
                                            size="24.0" />
                                    </font>
                                </Label>

                                <Label
                                    text="Consulta, registro, modificación y asignación de experiencia educativa."
                                    textFill="#64748b">

                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Button
                            fx:id="btnRegisterIntern"
                            mnemonicParsing="false"
                            onAction="#handleGoRegisterIntern"
                            prefHeight="38.0"
                            style="-fx-background-color: #3f8fe5; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                            text="+ Nuevo estudiante" />
                    </children>
                </HBox>

                <VBox
                    spacing="16.0"
                    style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e2e8f0; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 14, 0.16, 0, 4);">

                    <padding>
                        <Insets
                            bottom="20.0"
                            left="20.0"
                            right="20.0"
                            top="20.0" />
                    </padding>

                    <children>
                        <HBox
                            alignment="CENTER_LEFT"
                            spacing="10.0">

                            <children>
                                <TextField
                                    fx:id="txtSearchEnrollment"
                                    onAction="#handleSearchIntern"
                                    onKeyReleased="#handleSearchIntern"
                                    prefHeight="40.0"
                                    promptText="Buscar por matrícula, correo, nombre o NRC"
                                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #cbd5e1; -fx-padding: 0 14 0 14;"
                                    HBox.hgrow="ALWAYS" />

                                <Button
                                    fx:id="btnSearchIntern"
                                    mnemonicParsing="false"
                                    onAction="#handleSearchIntern"
                                    prefHeight="40.0"
                                    style="-fx-background-color: #14213d; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Buscar" />

                                <Button
                                    fx:id="btnRefreshInterns"
                                    mnemonicParsing="false"
                                    onAction="#handleRefreshInterns"
                                    prefHeight="40.0"
                                    style="-fx-background-color: #eef2f7; -fx-background-radius: 12; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Mostrar todos" />
                            </children>
                        </HBox>

                        <TableView
                            fx:id="tblInterns"
                            onMouseClicked="#handleSelectIntern"
                            prefHeight="320.0"
                            style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #dbe1ea; -fx-padding: 0; -fx-selection-bar: #dbeafe; -fx-selection-bar-non-focused: #dbeafe; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 12, 0.15, 0, 3);">

                            <columns>
                                <TableColumn
                                    fx:id="colEnrollment"
                                    text="Matrícula" />

                                <TableColumn
                                    fx:id="colName"
                                    text="Nombre" />

                                <TableColumn
                                    fx:id="colEmail"
                                    text="Correo institucional" />

                                <TableColumn
                                    fx:id="colNRC"
                                    text="NRC" />

                                <TableColumn
                                    fx:id="colStatus"
                                    text="Estado" />
                            </columns>
                        </TableView>

                        <HBox
                            alignment="CENTER_RIGHT"
                            spacing="10.0"
                            style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14;">

                            <padding>
                                <Insets
                                    bottom="12.0"
                                    left="14.0"
                                    right="14.0"
                                    top="12.0" />
                            </padding>

                            <children>
                                <Label
                                    text="Seleccione un estudiante para modificarlo o cambiar su estado."
                                    textFill="#64748b"
                                    HBox.hgrow="ALWAYS" />

                                <Button
                                    fx:id="btnUpdateIntern"
                                    mnemonicParsing="false"
                                    onAction="#handleUpdateIntern"
                                    prefHeight="38.0"
                                    style="-fx-background-color: #e0ecff; -fx-background-radius: 12; -fx-text-fill: #1d4ed8; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Modificar estudiante" />

                                <Button
                                    fx:id="btnChangeInternStatus"
                                    mnemonicParsing="false"
                                    onAction="#handleChangeInternStatus"
                                    prefHeight="38.0"
                                    style="-fx-background-color: #fee2e2; -fx-background-radius: 12; -fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 18 0 18;"
                                    text="Activar / Inactivar" />
                            </children>
                        </HBox>

                        <VBox
                            spacing="11.0"
                            style="-fx-background-color: #f8fafc; -fx-background-radius: 14; -fx-border-color: #e2e8f0; -fx-border-radius: 14;">

                            <padding>
                                <Insets
                                    bottom="15.0"
                                    left="15.0"
                                    right="15.0"
                                    top="15.0" />
                            </padding>

                            <children>
                                <Label
                                    text="Asignar experiencia educativa"
                                    textFill="#14213d">

                                    <font>
                                        <Font
                                            name="System Bold"
                                            size="16.0" />
                                    </font>
                                </Label>

                                <HBox
                                    alignment="CENTER_LEFT"
                                    spacing="10.0">

                                    <children>
                                        <ComboBox
                                            fx:id="cmbEducationalExperience"
                                            maxWidth="Infinity"
                                            prefHeight="40.0"
                                            promptText="Seleccione una experiencia educativa"
                                            style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #cbd5e1;"
                                            HBox.hgrow="ALWAYS" />

                                        <Button
                                            fx:id="btnAssignEducationalExperience"
                                            mnemonicParsing="false"
                                            onAction="#handleAssignEducationalExperience"
                                            prefHeight="40.0"
                                            style="-fx-background-color: #3f8fe5; -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0 20 0 20;"
                                            text="Asignar" />
                                    </children>
                                </HBox>

                                <Label
                                    text="Seleccione un estudiante de la tabla y después elija la experiencia educativa."
                                    textFill="#64748b"
                                    wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>