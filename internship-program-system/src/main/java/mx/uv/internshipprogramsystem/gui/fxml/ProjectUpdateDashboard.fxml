<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25.0.3"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ProjectUpdateDashboardController"
            prefHeight="720.0"
            prefWidth="1080.0"
            style="-fx-background-color: #f4f7fb;">

    <left>
        <VBox alignment="TOP_CENTER"
              prefWidth="70.0"
              spacing="20.0"
              style="-fx-background-color:#4a90e2;">

            <children>
                <StackPane prefHeight="40.0"
                           prefWidth="40.0"
                           style="-fx-background-color: #e8a020; -fx-background-radius: 10;">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>

                    <children>
                        <Label text="PC" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>

                <Button fx:id="btnHome"
                        onAction="#goHome"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="⌂"
                        textFill="WHITE"
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10;" />

                <Button fx:id="btnEducationalExperience"
                        onAction="#goEducationalExperienceModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="📚"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Button fx:id="btnIntern"
                        onAction="#goInternModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="👥"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Button fx:id="btnLinkedOrganization"
                        onAction="#goLinkedOrganizationModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="🏢"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Button fx:id="btnProjects"
                        onAction="#goProjectsModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="🛠️"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Button fx:id="btnDocuments"
                        onAction="#goDocumentsModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="📑"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Button fx:id="btnReports"
                        onAction="#goReportsModule"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="📋"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;" />

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnExit"
                        onAction="#logOut"
                        prefHeight="40.0"
                        prefWidth="40.0"
                        text="🚪"
                        textFill="WHITE"
                        style="-fx-background-color: transparent;">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0"
              style="-fx-padding: 30 40 30 40;">

            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label text="Registrar proyecto"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                    <Label text="Captura la información del proyecto, actividades del plan y horario estimado."
                           style="-fx-font-size: 14px; -fx-text-fill: #64748b;" />
                </VBox>

                <Button fx:id="btnCancel"
                        text="Cancelar"
                        onAction="#handleBtnCancel"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 22 12 22;" />

                <Button fx:id="btnSaveProject"
                        text="Guardar proyecto"
                        onAction="#handleBtnSaveProject"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24 12 24;" />
            </HBox>

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

                <content>
                    <VBox spacing="20.0"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #dbe1ea; -fx-padding: 26; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 12, 0.15, 0, 3);">

                        <Label text="Datos principales"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <VBox spacing="8.0">
                            <Label text="Nombre del proyecto"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                            <TextField fx:id="txtProjectName"
                                       promptText="Ej. Internship Program System"
                                       style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-padding: 10;" />
                        </VBox>

                        <HBox spacing="16.0">
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Metodología"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                                <TextField fx:id="txtMethodology"
                                           promptText="Ej. Scrum"
                                           style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-padding: 10;" />
                            </VBox>

                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Duración en horas"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                                <TextField fx:id="txtDuration"
                                           promptText="Ej. 420"
                                           style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-padding: 10;" />
                            </VBox>
                        </HBox>

                        <Label text="Asociación del proyecto"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <HBox spacing="16.0">
                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Organización vinculada"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                                <ComboBox fx:id="cmbOrganization"
                                          promptText="Selecciona una organización"
                                          maxWidth="Infinity"
                                          style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10;" />
                            </VBox>

                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                <Label text="Responsable del proyecto"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #334155;" />

                                <ComboBox fx:id="cmbResponsible"
                                          promptText="Selecciona un responsable"
                                          maxWidth="Infinity"
                                          style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10;" />
                            </VBox>
                        </HBox>

                        <Label text="Descripción y objetivos"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <TextArea fx:id="txaGeneralDescription"
                                  promptText="Descripción general"
                                  prefRowCount="3"
                                  wrapText="true" />

                        <TextArea fx:id="txaGeneralObjective"
                                  promptText="Objetivo general"
                                  prefRowCount="3"
                                  wrapText="true" />

                        <HBox spacing="16.0">
                            <TextArea fx:id="txaImmediateObjectives"
                                      promptText="Objetivos inmediatos"
                                      prefRowCount="4"
                                      wrapText="true"
                                      HBox.hgrow="ALWAYS" />

                            <TextArea fx:id="txaMediateObjectives"
                                      promptText="Objetivos mediatos"
                                      prefRowCount="4"
                                      wrapText="true"
                                      HBox.hgrow="ALWAYS" />
                        </HBox>

                        <Label text="Recursos y responsabilidades"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <TextArea fx:id="txaResources"
                                  promptText="Recursos humanos, materiales y económicos"
                                  prefRowCount="3"
                                  wrapText="true" />

                        <TextField fx:id="txtResponsibilities"
                                   promptText="Responsabilidades"
                                   style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-border-radius: 10; -fx-padding: 10;" />

                        <Label text="Actividades del plan de trabajo"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <HBox spacing="12.0">
                            <TextField fx:id="txtActivityName"
                                       promptText="Actividad"
                                       HBox.hgrow="ALWAYS" />

                            <TextField fx:id="txtActivityMonth"
                                       promptText="Mes"
                                       HBox.hgrow="ALWAYS" />

                            <TextField fx:id="txtActivityStartWeek"
                                       promptText="Semana inicio"
                                       prefWidth="120.0" />

                            <TextField fx:id="txtActivityEndWeek"
                                       promptText="Semana fin"
                                       prefWidth="120.0" />

                            <Button fx:id="btnAddActivity"
                                    text="+"
                                    onAction="#handleBtnAddActivity"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" />
                        </HBox>

                        <ListView fx:id="lstActivities"
                                  prefHeight="120.0"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;" />

                        <Button fx:id="btnRemoveActivity"
                                text="Eliminar actividad seleccionada"
                                onAction="#handleBtnRemoveActivity"
                                style="-fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-font-weight: bold;" />

                        <Label text="Horario del proyecto"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                        <Separator />

                        <HBox spacing="12.0">
                            <ComboBox fx:id="cmbScheduleDay"
                                      promptText="Día"
                                      prefWidth="180.0" />

                            <TextField fx:id="txtEntryTime"
                                       promptText="Entrada HH:mm"
                                       HBox.hgrow="ALWAYS" />

                            <TextField fx:id="txtExitTime"
                                       promptText="Salida HH:mm"
                                       HBox.hgrow="ALWAYS" />

                            <Button fx:id="btnAddSchedule"
                                    text="+"
                                    onAction="#handleBtnAddSchedule"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" />
                        </HBox>

                        <ListView fx:id="lstSchedules"
                                  prefHeight="120.0"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;" />

                        <Button fx:id="btnRemoveSchedule"
                                text="Eliminar horario seleccionado"
                                onAction="#handleBtnRemoveSchedule"
                                style="-fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-font-weight: bold;" />

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>