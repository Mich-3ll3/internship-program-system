<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0"
            prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #F4F4F9, #EDEBFA);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controllers.ForgotPasswordDashboardController">

    <children>
        <VBox alignment="CENTER"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

            <children>
                <VBox alignment="TOP_CENTER"
                      maxWidth="390.0"
                      prefWidth="390.0"
                      spacing="14.0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-border-radius: 18;
                             -fx-border-color: #E5E7EB;
                             -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.12), 18, 0.18, 0, 6);">

                    <padding>
                        <Insets bottom="32.0"
                                left="34.0"
                                right="34.0"
                                top="32.0" />
                    </padding>

                    <children>
                        <Label text="Recuperar contraseña"
                               style="-fx-font-size: 22;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1F2937;" />

                        <Label text="Ingresa tu correo, token y nueva contraseña."
                               wrapText="true"
                               textAlignment="CENTER"
                               style="-fx-font-size: 12;
                                      -fx-text-fill: #6B7280;" />

                        <Region prefHeight="4.0" />

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Correo institucional"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <TextField fx:id="txtInstitutionalEmail"
                                           prefHeight="38.0"
                                           promptText="ejemplo@estudiantes.uv.mx"
                                           style="-fx-background-color: #F9FAFB;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 8;
                                                  -fx-padding: 0 10 0 10;" />
                                <Button text="Enviar token de recuperación"
                                    maxWidth="Infinity"
                                    prefHeight="36.0"
                                    onAction="#handleSendRecoveryToken"
                                    style="-fx-background-color: #EEF2FF;
                                           -fx-text-fill: #534AB7;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Token de recuperación"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <TextField fx:id="txtRecoveryToken"
                                           prefHeight="38.0"
                                           promptText="Ingresa el token recibido"
                                           style="-fx-background-color: #F9FAFB;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #D1D5DB;
                                                  -fx-border-radius: 8;
                                                  -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Nueva contraseña"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <PasswordField fx:id="pwdNewPassword"
                                               prefHeight="38.0"
                                               promptText="Nueva contraseña"
                                               style="-fx-background-color: #F9FAFB;
                                                      -fx-background-radius: 8;
                                                      -fx-border-color: #D1D5DB;
                                                      -fx-border-radius: 8;
                                                      -fx-padding: 0 10 0 10;" />

                                <HBox alignment="CENTER"
                                      spacing="5.0">
                                    <children>
                                        <Pane fx:id="pneStrengthBarPart1"
                                              prefHeight="4.0"
                                              prefWidth="72.0"
                                              style="-fx-background-color: #E5E7EB;
                                                     -fx-background-radius: 10;" />

                                        <Pane fx:id="pneStrengthBarPart2"
                                              prefHeight="4.0"
                                              prefWidth="72.0"
                                              style="-fx-background-color: #E5E7EB;
                                                     -fx-background-radius: 10;" />

                                        <Pane fx:id="pneStrengthBarPart3"
                                              prefHeight="4.0"
                                              prefWidth="72.0"
                                              style="-fx-background-color: #E5E7EB;
                                                     -fx-background-radius: 10;" />

                                        <Pane fx:id="pneStrengthBarPart4"
                                              prefHeight="4.0"
                                              prefWidth="72.0"
                                              style="-fx-background-color: #E5E7EB;
                                                     -fx-background-radius: 10;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER_LEFT"
                              spacing="3.0"
                              style="-fx-background-color: #F9FAFB;
                                     -fx-background-radius: 10;
                                     -fx-padding: 10;">
                            <children>
                                <Label fx:id="lblMinLengthRequirement"
                                       text="• Mínimo 8 caracteres"
                                       textFill="GRAY"
                                       style="-fx-font-size: 10;" />

                                <Label fx:id="lblUppercaseRequirement"
                                       text="• Al menos una mayúscula"
                                       textFill="GRAY"
                                       style="-fx-font-size: 10;" />

                                <Label fx:id="lblNumberRequirement"
                                       text="• Al menos un número"
                                       textFill="GRAY"
                                       style="-fx-font-size: 10;" />

                                <Label fx:id="lblSymbolRequirement"
                                       text="• Al menos un símbolo (@#$%^&amp;+=!)"
                                       textFill="GRAY"
                                       style="-fx-font-size: 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Confirmar contraseña"
                                       style="-fx-font-size: 11;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #374151;" />

                                <PasswordField fx:id="pwdConfirmPassword"
                                               prefHeight="38.0"
                                               promptText="Confirma tu contraseña"
                                               style="-fx-background-color: #F9FAFB;
                                                      -fx-background-radius: 8;
                                                      -fx-border-color: #D1D5DB;
                                                      -fx-border-radius: 8;
                                                      -fx-padding: 0 10 0 10;" />
                                <Label fx:id="lblPasswordMatch"
                                    text=""
                                    visible="false"
                                    managed="false"
                                    style="-fx-font-size: 10;" />
                            </children>
                        </VBox>

                        <Button text="Cambiar contraseña"
                                maxWidth="Infinity"
                                prefHeight="42.0"
                                onAction="#handleResetPassword"
                                style="-fx-background-color: #534AB7;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;" />

                        <Button text="Volver al inicio de sesión"
                                maxWidth="Infinity"
                                prefHeight="36.0"
                                onAction="#handleBackToLogin"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #534AB7;
                                       -fx-font-weight: bold;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>