<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0"
            prefWidth="1000.0"
            style="-fx-background-color: #f5f6fa;"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.uv.internshipprogramsystem.gui.controller.RegisterInternFormController">
    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Registrar estudiante" textFill="#1a2744">
                        <font>
                            <Font name="System Bold" size="22.0" />
                        </font>
                    </Label>
                    <Label text="Capture los datos requeridos para validar el registro del estudiante." textFill="#6b7280" />
                </VBox>
            </HBox>

            <VBox spacing="14.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 12;">
                <padding>
                    <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                </padding>
                <GridPane hgap="14.0" vgap="12.0">
                    <Label text="Correo institucional" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtInstitutionalEmail" promptText="ejemplo@estudiantes.uv.mx" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <Label text="Contraseña" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <PasswordField fx:id="txtPassword" promptText="Mínimo 8 caracteres" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <Label text="Nombre" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtName" promptText="Nombre(s)" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    <Label text="Apellido paterno" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="txtFirstSurname" promptText="Apellido paterno" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    <Label text="Apellido materno" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <TextField fx:id="txtSecondSurname" promptText="Apellido materno" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    <Label text="Matrícula" textFill="#1a2744" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <TextField fx:id="txtEnrollment" promptText="zS12345678" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                </GridPane>

                <Label text="Validaciones: correo institucional, contraseña segura, campos obligatorios y matrícula con formato zS + 8 dígitos."
                       textFill="#6b7280"
                       wrapText="true" />

                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false"
                            onAction="#clearForm"
                            style="-fx-background-color: #f5f6fa; -fx-background-radius: 8; -fx-border-color: rgba(0,0,0,0.08); -fx-border-radius: 8; -fx-text-fill: #6b7280;"
                            text="Cancelar" />
                    <Button mnemonicParsing="false"
                            onAction="#validateRegisterInternForm"
                            style="-fx-background-color: #4a90e2; -fx-background-radius: 8; -fx-text-fill: white;"
                            text="Validar registro" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
